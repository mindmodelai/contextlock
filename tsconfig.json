{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true
  },
  "files": [],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/cli-publisher" },
    { "path": "packages/cli-user" },
    { "path": "packages/adapter-claude-code" },
    { "path": "packages/adapter-openclaw" }
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
